{
  "name": "open-slide-studio",
  "productName": "open-slide studio",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "description": "Bundled desktop GUI: simplified opencode agent chat (left) + open-slide live web view (right). For non-engineers to build slides by natural language.",
  "main": "src/main.js",
  "author": "Binghan Lin",
  "repository": {
    "type": "git",
    "url": "https://github.com/BingHanLin/open-slide-studio.git"
  },
  "homepage": "https://github.com/BingHanLin/open-slide-studio",
  "bugs": "https://github.com/BingHanLin/open-slide-studio/issues",
  "scripts": {
    "start": "electron .",
    "init-slides": "npx --yes @open-slide/cli init slides --use-npm --no-git",
    "gen-icon": "electron tools/gen-icon.js",
    "test": "node --check src/main.js && node --check src/preload.js && node --check tools/gen-icon.js && node --check build/after-pack.js",
    "test:e2e": "node smoke-test.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "studio.openslide.app",
    "productName": "open-slide studio",
    "artifactName": "${name}-Setup-${version}.${ext}",
    "icon": "build/icon",
    "publish": [
      {
        "provider": "github",
        "owner": "BingHanLin",
        "repo": "open-slide-studio"
      }
    ],
    "files": [
      "**/*",
      "!slides/**",
      "!tools/**",
      "!build/icon.svg",
      "!build/after-pack.js",
      "!docs/**",
      "!*.mjs",
      "!screenshot.png",
      "!crop.png",
      "!user-settings.json",
      "!node_modules/opencode-windows-*/**",
      "!node_modules/opencode-darwin-*/**",
      "!node_modules/opencode-linux-*/**"
    ],
    "asarUnpack": [
      "node_modules/opencode-ai/bin/**"
    ],
    "afterPack": "build/after-pack.js",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.4",
    "electron-updater": "^6.8.9",
    "opencode-ai": "^1.17.4",
    "undici": "^7.27.2"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}
